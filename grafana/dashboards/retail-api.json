      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "VUs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
