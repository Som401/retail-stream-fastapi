    {
      "title": "k6 — Iterations per Second",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(k6_iterations_total[30s])",
          "legendFormat": "iter/s"
